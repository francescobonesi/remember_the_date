<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.RememberTheDate" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- This tells the theme we will handle the ActionBar ourselves -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/teal_200</item>
        <item name="colorPrimaryVariant">@color/teal_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/orange_A200</item>
        <item name="colorSecondaryVariant">@color/orange_A400</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- ... (rest of style) ... -->
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.RememberTheDate" parent="Base.Theme.RememberTheDate" />

    <style name="Theme.RememberTheDate.DatePicker" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <item name="android:datePickerStyle">@style/Widget.RememberTheDate.DatePicker</item>
    </style>

    <style name="Widget.RememberTheDate.DatePicker" parent="android:Widget.Material.Light.DatePicker">
        <item name="android:datePickerMode">spinner</item>
        <item name="android:calendarViewShown">false</item>
        <item name="android:yearListSelectorColor">@android:color/transparent</item>
    </style>
</resources>